{
  "__inputs": [],
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
    {
      "title": "Fleet Stats",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": "mysql",
      "targets": [
        {
          "rawSql": "SELECT AVG(a.overall_score) AS 'Avg Score'\nFROM _tool_agentready_assessments a\nINNER JOIN (\n  SELECT aa.repo_id, MAX(aa.assessed_at) as max_assessed\n  FROM _tool_agentready_assessments aa\n  JOIN project_mapping pm ON aa.repo_id = pm.row_id AND pm.`table` = 'repos'\n  WHERE aa.id != '' AND pm.project_name in (${project})\n  GROUP BY aa.repo_id\n) latest ON a.repo_id = latest.repo_id AND a.assessed_at = latest.max_assessed",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 40 },
              { "color": "yellow", "value": 60 },
              { "color": "green", "value": 80 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "title": "Total Repos Assessed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": "mysql",
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT a.repo_id) AS 'Total Repos'\nFROM _tool_agentready_assessments a\nJOIN project_mapping pm ON a.repo_id = pm.row_id AND pm.`table` = 'repos'\nWHERE a.id != '' AND pm.project_name in (${project})",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Certification Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "mysql",
      "targets": [
        {
          "rawSql": "SELECT\n  a.certification_level AS metric,\n  COUNT(*) AS value\nFROM _tool_agentready_assessments a\nINNER JOIN (\n  SELECT aa.repo_id, MAX(aa.assessed_at) as max_assessed\n  FROM _tool_agentready_assessments aa\n  JOIN project_mapping pm ON aa.repo_id = pm.row_id AND pm.`table` = 'repos'\n  WHERE aa.id != '' AND pm.project_name in (${project})\n  GROUP BY aa.repo_id\n) latest ON a.repo_id = latest.repo_id AND a.assessed_at = latest.max_assessed\nGROUP BY a.certification_level",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": true,
          "calcs": []
        },
        "pieType": "donut",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        }
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Platinum" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#E5E4E2" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Gold" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FFD700" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Silver" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#C0C0C0" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Bronze" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#CD7F32" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Needs Improvement" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF4444" } }]
          },
          {
            "matcher": { "id": "byName", "options": "None" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#808080" } }]
          }
        ]
      }
    },
    {
      "title": "Score by Repository",
      "type": "table",
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 4 },
      "datasource": "mysql",
      "targets": [
        {
          "rawSql": "SELECT\n  a.repo_name,\n  a.overall_score,\n  a.certification_level,\n  a.attributes_assessed,\n  a.attributes_total,\n  a.assessed_at\nFROM _tool_agentready_assessments a\nINNER JOIN (\n  SELECT aa.repo_id, MAX(aa.assessed_at) as max_assessed\n  FROM _tool_agentready_assessments aa\n  JOIN project_mapping pm ON aa.repo_id = pm.row_id AND pm.`table` = 'repos'\n  WHERE aa.id != '' AND pm.project_name in (${project})\n  GROUP BY aa.repo_id\n) latest ON a.repo_id = latest.repo_id AND a.assessed_at = latest.max_assessed\nORDER BY a.overall_score DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "overall_score" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "gauge", "mode": "gradient" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "orange", "value": 40 },
                    { "color": "yellow", "value": 60 },
                    { "color": "green", "value": 80 }
                  ]
                }
              },
              { "id": "max", "value": 100 }
            ]
          }
        ]
      }
    },
    {
      "title": "Average Score Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "mysql",
      "targets": [
        {
          "rawSql": "SELECT\n  DATE(a.assessed_at) AS time,\n  AVG(a.overall_score) AS 'Average Score'\nFROM _tool_agentready_assessments a\nINNER JOIN (\n  SELECT aa.repo_id, DATE(aa.assessed_at) AS day, MAX(aa.assessed_at) AS max_assessed\n  FROM _tool_agentready_assessments aa\n  JOIN project_mapping pm ON aa.repo_id = pm.row_id AND pm.`table` = 'repos'\n  WHERE aa.id != '' AND pm.project_name in (${project})\n  GROUP BY aa.repo_id, DATE(aa.assessed_at)\n) latest ON a.repo_id = latest.repo_id AND DATE(a.assessed_at) = latest.day AND a.assessed_at = latest.max_assessed\nWHERE $__timeFilter(a.assessed_at)\nGROUP BY DATE(a.assessed_at)\nORDER BY time",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "min": 0,
          "max": 100,
          "unit": "none"
        }
      }
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["agentready", "devlake"],
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": ["All"],
          "value": ["$__all"]
        },
        "datasource": "mysql",
        "definition": "select distinct name from projects",
        "hide": 0,
        "includeAll": true,
        "label": "Project",
        "multi": true,
        "name": "project",
        "options": [],
        "query": "select distinct name from projects",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 0,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-90d",
    "to": "now"
  },
  "title": "AgentReady - Fleet Overview",
  "uid": "agentready-fleet-overview"
}
